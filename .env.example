# Copy to .env and fill in. Never commit .env.
ANTHROPIC_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional: fast-flights fetch mode. Default is "common" (direct HTTP to Google).
# Other options: "fallback" (tries common, falls back to a paid Playwright service),
# "local" (runs Playwright locally — heavy but most reliable).
# FAST_FLIGHTS_MODE=common
